OPENAI_API_KEY=sk-...
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret

# Optional: enables Serper as the first-tier band link search (Google search
# results as JSON, via https://serper.dev). Sign up for a free API key at
# https://serper.dev/signup (no credit card required, 2,500 free queries).
# If unset, band lookup falls back to Bing/DuckDuckGo automatically.
SERPER_API_KEY=your_serper_api_key
